# ============================================================
# Gartenwoche Clone — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── OpenWeatherMap (for weather widget in HeaderMain) ───────
# Get a free key at https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# ─── Site URL ────────────────────────────────────────────────
# Used for canonical URLs, OG tags, and sitemap
PUBLIC_SITE_URL=https://gartenwoche.ch

# ─── Node environment ────────────────────────────────────────
NODE_ENV=production

# ─── Server port (adapter-node) ──────────────────────────────
PORT=3000
HOST=0.0.0.0

# ─── Google Analytics (optional) ─────────────────────────────
# PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Sentry (optional) ───────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ─── Redis cache (optional, future) ──────────────────────────
# REDIS_URL=redis://localhost:6379
