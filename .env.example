# ══════════════════════════════════════════════════════════
# GARTENWOCHE — ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Never commit .env to git!

# ── WordPress REST API ────────────────────────────────────
PUBLIC_WP_URL=https://gartenwoche.ch/wp-json
WP_API_BASE=https://gartenwoche.ch/wp-json/wp/v2

# ── HeadlessKey plugin (auth backend) ─────────────────────
# Required. Handles login, register, validate, refresh, revoke,
# forgot/reset/change password. The standard jwt-auth/v1 plugin
# on this server is misconfigured (missing JWT_AUTH_SECRET_KEY)
# and is intentionally NOT used.
WP_HEADLESSKEY_BASE=https://gartenwoche.ch/wp-json/headlesskey/v1

# ── Session cookie ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Currently unused (we store the raw HeadlessKey JWT in an HttpOnly cookie),
# but reserved for future client-side signing if we ever wrap the token.
AUTH_SECRET=change-me-to-32-random-bytes

# ── Weather (optional) ────────────────────────────────────
# Get a free key at https://openweathermap.org/api
# Without key: shows static "—°C Zürich"
WEATHER_API_KEY=

# ── Site URL (used for sitemap + canonical) ───────────────
PUBLIC_SITE_URL=https://garten-woche.vercel.app

# ── Google AdSense (optional) ─────────────────────────────
# Get from https://adsense.google.com after approval
PUBLIC_ADSENSE_CLIENT=
PUBLIC_ADSENSE_SLOT_SIDEBAR=
PUBLIC_ADSENSE_SLOT_MID_ARTICLE=
PUBLIC_ADSENSE_SLOT_LEADERBOARD=

# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
