# ══════════════════════════════════════════════════════════
# GARTENWOCHE — ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# Never commit .env to git!

# ── WordPress REST API ────────────────────────────────────
WP_URL=https://gartenwoche.ch
# Secret from wp-config.php: define('JWT_AUTH_SECRET_KEY', '...')
WP_JWT_SECRET=your-jwt-secret-from-wp-config

# ── Weather (optional) ────────────────────────────────────
# Get a free key at https://openweathermap.org/api
# Without key: shows static "—°C Zürich"
WEATHER_API_KEY=

# ── Site URL (used for sitemap + canonical) ───────────────
PUBLIC_SITE_URL=https://garten-woche.vercel.app

# ── Google AdSense (optional) ─────────────────────────────
# Get from https://adsense.google.com after approval
PUBLIC_ADSENSE_CLIENT=
PUBLIC_ADSENSE_SLOT_SIDEBAR=
PUBLIC_ADSENSE_SLOT_MID_ARTICLE=
PUBLIC_ADSENSE_SLOT_LEADERBOARD=

# ── Server ────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

